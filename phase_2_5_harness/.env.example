# Phase 2.5 harness credentials (all optional; missing keys -> detector is skipped in auto mode).
# Copy to .env and fill in the ones you want to exercise. Never commit .env.

# GPTZero — free tier, public API.
# Docs: https://gptzero.stoplight.io  |  https://gptzero.me/developers
GPTZERO_API_KEY=

# Sapling — free tier (lower character cap).
# Docs: https://sapling.ai/docs/api/detector
SAPLING_API_KEY=

# Originality.ai — paid / credit-based.
# Docs: https://docs.originality.ai
ORIGINALITY_API_KEY=

# ZeroGPT — public API (tier-dependent).
# Docs: https://www.zerogpt.com/
ZEROGPT_API_KEY=

# Copyleaks — paid; two-credential auth (email + API key).
# Docs: https://api.copyleaks.com/documentation/v3
COPYLEAKS_API_KEY=
COPYLEAKS_EMAIL=

# Winston AI — trial / paid.
# Docs: https://gowinston.ai/developers-api
WINSTON_API_KEY=

# --- Runner behavior -----------------------------------------------------------
# Comma-separated detector names to enable, or "auto" to include every detector
# whose required credentials are present.
DETECTORS_ENABLED=auto

# Per-detector request pacing (seconds between submissions). Each adapter may
# override.
DEFAULT_RATE_LIMIT_SECONDS=2.0

# Per-request hard timeout (seconds).
DEFAULT_TIMEOUT_SECONDS=30.0
