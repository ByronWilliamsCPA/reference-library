# Secrets — never commit.
.env
.env.local
.env.*.local

# Poetry / Python.
.venv/
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/

# Parsed samples and run results.
# Samples are regenerated from phase_2_5_samples.md via parse-samples; the
# results directory holds per-run JSON checkpoints that may echo sample text
# inside raw vendor responses.
data/samples/*.md
data/results/*.json
!data/samples/.gitkeep
!data/results/.gitkeep

# IDE / OS.
.DS_Store
.idea/
.vscode/
