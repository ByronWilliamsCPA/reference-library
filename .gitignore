# PDF source files (large binaries - keep locally, don't commit)
legal-style/source-pdfs/*.pdf

# Raw text intermediates (generated from PDFs - reproducible)
legal-style/source-pdfs/raw-text/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Qlty runtime artifacts (only qlty.toml belongs in the repo).
# No trailing slash: qlty creates these as symlinks, and a trailing-slash
# pattern matches directories only, so the symlinks would slip through.
.qlty/logs
.qlty/out
.qlty/plugin_cachedir
.qlty/results
.qlty/sources

# OS
.DS_Store
Thumbs.db

.env

# Worktrees (always created inside project at .worktrees/<branch-slug>)
.worktrees/

# Compliance reports (generated, not committed)
docs/compliance-reports/

# Superpowers working directory (plans, scratch notes; not tracked)
docs/superpowers/

# V2 profile config (active values live locally; only profiles.example.toml is committed)
config/profiles.toml
config/profiles/
